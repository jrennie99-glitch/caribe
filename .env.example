# Copy to .env and fill in. NEVER commit .env.
# Generate secrets with:  openssl rand -hex 48   (and  openssl rand -hex 24  for ADMIN_KEY)

DOMAIN=caribe.yourdomain.com
TOKEN_SECRET=replace-with-64+-char-random-hex
ADMIN_KEY=replace-with-32+-char-random-hex

# Live Sand Dollar network (leave BLANK to run on the internal settlement engine).
# Provided by the Central Bank of The Bahamas once you are an authorized operator.
SD_BASE_URL=
SD_API_KEY=
